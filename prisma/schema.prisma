generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model feedbacks_table {
  id            Int      @id @default(autoincrement())
  rating        Int      @db.SmallInt
  date_time     DateTime @default(now()) @db.Timestamptz(6)
  feedback_text String?
}
